# =============================================================================
# Bouldering Analysis — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables are prefixed with BA_.
# .env is gitignored — never commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
BA_APP_NAME=bouldering-analysis
BA_APP_VERSION=0.1.0

# Set to false in production (hides /docs, /redoc, /openapi.json)
BA_DEBUG=false

BA_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Lock down to your frontend URL in production.
# Local dev: leave unset or use ["*"]
# Production: set to exact origin(s), e.g. ["https://custom-domain.vercel.app"]
# Multiple origins: ["https://custom-domain.vercel.app","https://your-custom-domain.com"]
BA_CORS_ORIGINS=["https://custom-domain.vercel.app"]

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Project URL from: Supabase Dashboard → Project Settings → API
BA_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Service role key (not the anon key) — keep this secret
# From: Supabase Dashboard → Project Settings → API → service_role
BA_SUPABASE_KEY=<your-service-role-key>

# PostgREST request timeout in seconds (default: 10)
# BA_SUPABASE_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Require X-API-Key header on all non-health endpoints.
# Leave empty to disable authentication (not recommended for production).
BA_API_KEY=<your-random-secret>

# Max upload requests per IP per minute (0 = disabled)
# BA_RATE_LIMIT_UPLOAD=10

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
# BA_MAX_UPLOAD_SIZE_MB=10
# BA_STORAGE_BUCKET=route-images
# BA_ALLOWED_IMAGE_TYPES=["image/jpeg","image/png"]

# -----------------------------------------------------------------------------
# ML Model Paths
# -----------------------------------------------------------------------------
# Absolute paths to model files on the server.
# Leave empty to disable that stage (analysis endpoint returns 503).

# YOLOv8 detection weights (.pt file)
BA_DETECTION_MODEL_PATH=/models/detection/best.pt

# Hold type classification weights (.pt file)
BA_CLASSIFICATION_MODEL_PATH=/models/classification/best.pt

# XGBoost grade estimator directory (contains model.pkl + metadata.json)
# Leave empty to use heuristic-only grading.
BA_ML_GRADE_MODEL_PATH=/models/grading/v20260101_120000

# -----------------------------------------------------------------------------
# Inference
# -----------------------------------------------------------------------------
# Timeout in seconds for ML inference pipeline (default: 30)
# Increase if your deployment has slow cold starts.
# BA_INFERENCE_TIMEOUT_SECONDS=30
